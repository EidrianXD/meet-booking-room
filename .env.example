# ===========================================================================
# Variáveis do docker-compose.yml (raiz)
# Copie para `.env` e ajuste os valores. O `.env` não é versionado.
# ===========================================================================

# -- Backend ---------------------------------------------------------------
# Segredo usado para assinar os JWT. Em produção, gere com `openssl rand -hex 32`.
JWT_SECRET=troque-este-segredo-em-producao

# Liga (true) ou desliga (false) o seed de dados iniciais (3 salas + 3 usuários
# john/mary/alice, senha 123456). O seed é idempotente (upsert). Recomendado
# true para dev/demo, false para produção real.
SEED_ON_BOOT=true

# -- Rede / portas ---------------------------------------------------------
# Porta exposta no host pelo frontend (Nginx). Acesse em http://localhost:${FRONTEND_PORT}.
FRONTEND_PORT=8080

# -- Frontend (build-time) -------------------------------------------------
# Base da API embutida no bundle. O default `/api` casa com o reverse proxy
# do Nginx (location /api/ -> http://backend:3000/). Só sobrescreva se a SPA
# vai ser servida em um domínio separado do backend.
VITE_API_BASE_URL=/api

# -- Tags de imagem (preenchidas pelo Jenkins no deploy) -------------------
# Em desenvolvimento local, deixe vazio (vai usar `dev`). No Jenkins, o
# stage de deploy seta com o commit SHA-7 da build atual, garantindo que
# `docker compose pull` puxe exatamente a imagem que acabou de subir no GHCR.
# BACKEND_TAG=dev
# FRONTEND_TAG=dev
